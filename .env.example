# Copy this file to .env (DO NOT commit .env)
#
# 3-of-5 multisig: provide any 3 matching WIF keys
AVN_PRIVKEYS=wif1,wif2,wif3

# Optional override (defaults to the script's built-in redeemScript)
# AVN_REDEEM_SCRIPT=5321...

# --- create_avn_tx.py options ---
# Destination address for the outputs
AVN_DEST_ADDRESS=RMvB69eNSmsho8rMTVGESRwmbjpXA3XnRF

# UTXO JSON input file
# (Recommend keeping this under inputs/; that folder is ignored by git)
# AVN_UTXO_JSON=inputs/utxos.json

# --- fetch_avn_utxos.py options (getaddressutxos pagination) ---
# Avian Core RPC settings (requires addressindex enabled)
# You can set either AVN_RPC_URL or AVN_RPC_HOST/PORT.
# AVN_RPC_URL=http://127.0.0.1:8766/
# AVN_RPC_HOST=127.0.0.1
# AVN_RPC_PORT=8766
# AVN_RPC_USER=rpcuser
# AVN_RPC_PASSWORD=rpcpassword

# Source address(es) to fetch UTXOs for (comma-separated)
# AVN_SOURCE_ADDRESSES=RLrUNsda3Dqf6NBgChBUj26yg4jTkAYi5U

# Paging controls for large wallets
# AVN_RPC_LIMIT=5000
# AVN_RPC_OFFSET=0
# Optional pause between pages (seconds)
# AVN_RPC_SLEEP=0

# Transaction splitting / limits
# AVN_MAX_INPUTS=100
# AVN_TOTAL_PAYMENTS=300000000000000

# Flat fee used by the script's current logic
# AVN_FEE=100000

# --- broadcast_avn.py options ---
# By default, broadcast_avn.py will use Avian Core JSON-RPC (sendrawtransaction)
# if AVN_RPC_URL (or AVN_RPC_HOST/PORT) is configured; otherwise it falls back
# to the public explorer API.
# AVN_BROADCAST_METHOD=rpc
# AVN_BROADCAST_METHOD=explorer
# AVN_BROADCAST_DEBUG=false
